<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APAC Program Hub · May–June 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --teal:#0097A7; --teal-d:#00737E; --teal-deep:#004D58; --teal-l:#E0F5F7; --teal-m:#B2E4EA;
  --c-pe:#0097A7;   --l-pe:#E0F5F7;   --t-pe:#004D58;
  --c-re:#3949AB;   --l-re:#E8EAF6;   --t-re:#1A237E;
  --c-mkt:#7B1FA2;  --l-mkt:#F3E5F5;  --t-mkt:#4A148C;
  --c-ppl:#2E7D32;  --l-ppl:#E8F5E9;  --t-ppl:#1B5E20;
  --c-exec:#455A64; --l-exec:#ECEFF1; --t-exec:#263238;
  --c-cult:#AD1457; --l-cult:#FCE4EC; --t-cult:#880E4F;
  --c-ptnr:#D84315; --l-ptnr:#FBE9E7; --t-ptnr:#7D2000;
  --gray-bg:#F0F4F5; --gray-b:#D5E1E4; --gray-l:#EBF0F2;
  --gray-t:#4A6268;  --gray-m:#8BA6AA; --text:#1A2B2E;
}
body { font-family:'Outfit',system-ui,sans-serif; background:var(--gray-bg); color:var(--text); -webkit-font-smoothing:antialiased; min-height:100vh; }

/* ── HEADER ── */
.header { background:var(--teal); padding:0 40px; display:flex; align-items:center; justify-content:space-between; min-height:72px; }
.hdr-eyebrow { font-size:10px; font-weight:600; letter-spacing:2px; text-transform:uppercase; opacity:.7; margin-bottom:4px; color:white; }
.hdr-title { font-size:20px; font-weight:600; letter-spacing:-.3px; color:white; }
.logo-wrap { display:flex; align-items:center; gap:10px; }
.logo-mark { width:32px; height:32px; background:rgba(255,255,255,.2); border-radius:8px; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:14px; color:white; }
.logo-text { font-size:16px; font-weight:600; letter-spacing:-.4px; color:rgba(255,255,255,.92); }

/* ── STATS BAR ── */
.stats-bar { background:var(--teal-d); padding:0 40px; display:flex; height:56px; align-items:center; overflow-x:auto; }
.stat-item { display:flex; align-items:center; gap:10px; padding:0 24px; border-right:1px solid rgba(255,255,255,.12); flex-shrink:0; }
.stat-item:first-child { padding-left:0; }
.stat-num { font-size:20px; font-weight:700; color:white; }
.stat-label { font-size:11px; color:rgba(255,255,255,.7); line-height:1.3; }

/* ── MAIN ── */
.main { max-width:1200px; margin:0 auto; padding:28px 40px 60px; }

/* ── VIEW TOGGLE + MONTH TABS ── */
.top-controls { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:24px; }
.view-toggle { display:flex; background:white; border-radius:10px; padding:4px; border:1.5px solid var(--gray-b); }
.view-btn { padding:7px 18px; border-radius:7px; font-size:13px; font-weight:500; color:var(--gray-t); cursor:pointer; border:none; background:transparent; font-family:'Outfit',sans-serif; transition:all .15s; }
.view-btn:hover:not(.active) { color:var(--text); background:var(--gray-l); }
.view-btn.active { background:var(--teal); color:white; font-weight:600; }
.month-tabs { display:flex; background:white; border-radius:10px; padding:4px; border:1.5px solid var(--gray-b); }
.month-btn { padding:7px 20px; border-radius:7px; font-size:13px; font-weight:500; color:var(--gray-t); cursor:pointer; border:none; background:transparent; font-family:'Outfit',sans-serif; transition:all .15s; display:flex; align-items:center; gap:7px; }
.month-btn:hover:not(.active) { color:var(--text); background:var(--gray-l); }
.month-btn.active { background:var(--teal); color:white; font-weight:600; }
.month-btn-count { width:18px; height:18px; border-radius:50%; display:inline-flex; align-items:center; justify-content:center; font-size:10px; font-weight:700; background:rgba(255,255,255,.25); color:white; }
.month-btn:not(.active) .month-btn-count { background:var(--gray-l); color:var(--gray-m); }
.updated-label { font-size:12px; color:var(--gray-m); }
.updated-label strong { color:var(--gray-t); }

/* ── PANELS ── */
.panel { display:none; }
.panel.active { display:block; }

/* ── LEGEND ── */
.legend-bar { display:flex; gap:12px; flex-wrap:wrap; align-items:center; padding:11px 16px; background:white; border-radius:10px; border:1.5px solid var(--gray-b); margin-bottom:20px; font-size:12px; color:var(--gray-t); }
.legend-title { font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.6px; color:var(--gray-m); }
.leg { display:flex; align-items:center; gap:5px; }
.leg-dot { width:8px; height:8px; border-radius:2px; flex-shrink:0; }

/* ── FILTERS ── */
.filters-row { display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-bottom:24px; padding:12px 16px; background:white; border-radius:10px; border:1.5px solid var(--gray-b); }
.filter-label { font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.7px; color:var(--gray-m); }
.filter-divider { width:1px; height:18px; background:var(--gray-b); margin:0 2px; }
.filter-btn { padding:4px 12px; border-radius:20px; font-size:12px; font-weight:500; cursor:pointer; border:1.5px solid var(--gray-b); background:transparent; color:var(--gray-t); transition:all .12s; font-family:'Outfit',sans-serif; }
.filter-btn:hover:not(.active) { border-color:var(--teal); color:var(--teal); }
.filter-btn.active { background:var(--teal); border-color:var(--teal); color:white; font-weight:600; }

/* ── TEAM SUMMARIES ── */
.ts-section { margin-bottom:24px; }
.ts-heading { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:var(--gray-m); margin-bottom:10px; }
.ts-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:10px; }
.ts-card { background:white; border-radius:10px; border:1.5px solid var(--gray-b); border-left:3px solid #ccc; padding:12px 14px; }
.ts-badge { display:inline-block; padding:2px 8px; border-radius:4px; font-size:11px; font-weight:600; margin-bottom:6px; }
.ts-count { font-size:13px; font-weight:600; color:var(--text); margin-bottom:4px; }
.ts-desc { font-size:11.5px; color:var(--gray-t); line-height:1.45; }
.ts-tbc-badge { background:#FFF3E0; color:#8D4300; }

/* ── SECTION HEADERS ── */
.section-hdr { display:flex; align-items:center; gap:10px; margin-bottom:12px; margin-top:4px; }
.section-icon { width:26px; height:26px; border-radius:7px; display:flex; align-items:center; justify-content:center; font-size:13px; flex-shrink:0; }
.si-done { background:var(--l-ppl); } .si-up { background:var(--teal-l); } .si-tbc-s { background:#FFF3E0; }
.section-hdr-text h3 { font-size:14px; font-weight:600; }
.section-hdr-text p { font-size:12px; color:var(--gray-m); margin-top:1px; }

/* ── CARDS ── */
.cards-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(288px,1fr)); gap:12px; margin-bottom:28px; }
.card { background:white; border-radius:12px; padding:16px 18px 14px; border:1.5px solid var(--gray-b); cursor:pointer; transition:transform .15s, box-shadow .15s, border-color .15s; position:relative; }
.card:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(0,0,0,.08); border-color:var(--teal-m); }
.card.completed-card { background:#FAFEFE; }
.card.tbc-card { border-left:3.5px solid #D84315; padding-left:15px; }
.card-top { display:flex; align-items:flex-start; justify-content:space-between; gap:8px; margin-bottom:10px; }
.card-badge { display:inline-flex; align-items:center; font-size:10.5px; font-weight:600; padding:3px 8px; border-radius:20px; white-space:nowrap; flex-shrink:0; }
.b-done { background:var(--l-ppl); color:var(--c-ppl); }
.b-up { background:var(--teal-l); color:var(--teal-d); }
.b-tbc { background:#FFF3E0; color:#D84315; animation:tbcpulse 2.5s ease-in-out infinite; }
@keyframes tbcpulse { 0%,100%{opacity:1} 50%{opacity:.6} }
.card-date { font-size:11.5px; font-weight:600; color:var(--teal-d); white-space:nowrap; flex-shrink:0; }
.card-date.tbc-d { color:#D84315; }
.card-title { font-size:14px; font-weight:600; color:var(--text); line-height:1.4; margin-bottom:10px; }
.card-divider { height:1px; background:var(--gray-l); margin:9px 0; }
.card-meta { display:flex; flex-direction:column; gap:4px; }
.meta-row { display:flex; align-items:flex-start; gap:7px; }
.meta-key { min-width:46px; font-size:10.5px; font-weight:600; text-transform:uppercase; letter-spacing:.4px; color:var(--gray-m); padding-top:1px; flex-shrink:0; }
.meta-val { font-size:12px; color:var(--gray-t); line-height:1.4; flex:1; }
.chip-row { display:flex; gap:4px; flex-wrap:wrap; }
.chip { display:inline-block; padding:2px 7px; border-radius:4px; font-size:11px; font-weight:600; line-height:1.6; }
.chip-pe   { background:var(--l-pe);   color:var(--t-pe); }
.chip-re   { background:var(--l-re);   color:var(--t-re); }
.chip-mkt  { background:var(--l-mkt);  color:var(--t-mkt); }
.chip-ppl  { background:var(--l-ppl);  color:var(--t-ppl); }
.chip-exec { background:var(--l-exec); color:var(--t-exec); }
.chip-cult { background:var(--l-cult); color:var(--t-cult); }
.chip-ptnr { background:var(--l-ptnr); color:var(--t-ptnr); }
.type-chip { display:inline-block; padding:2px 7px; border-radius:4px; font-size:11px; font-weight:500; background:var(--gray-l); color:var(--gray-t); border:1px solid var(--gray-b); }
.view-details { font-size:11px; color:var(--teal); font-weight:600; margin-top:10px; display:block; }
.card.hidden { display:none; }
.tbc-callout { background:#FFF8E1; border:1.5px solid #FFCC80; border-radius:10px; padding:12px 16px; font-size:13px; color:#5D3A00; line-height:1.5; margin-bottom:14px; }

/* ── CALENDAR ── */
.cal-month-wrap { margin-bottom:32px; }
.cal-month-hdr { display:flex; align-items:baseline; justify-content:space-between; margin-bottom:10px; }
.cal-month-title { font-size:20px; font-weight:700; letter-spacing:-.4px; }
.cal-month-sub { font-size:12px; color:var(--gray-m); }
.cal-grid { display:grid; grid-template-columns:repeat(7,1fr); border:1.5px solid var(--gray-b); border-radius:12px; overflow:hidden; background:var(--gray-b); gap:1px; }
.cal-dow { background:var(--gray-l); padding:7px 5px; text-align:center; font-size:10.5px; font-weight:700; color:var(--gray-m); text-transform:uppercase; letter-spacing:.5px; }
.cal-cell { background:white; padding:7px 5px; min-height:96px; display:flex; flex-direction:column; gap:2px; }
.cal-cell.empty { background:#F7F9FA; }
.cal-cell.cal-weekend { background:#FAFBFC; }
.cal-cell.cal-past { background:#FAFBFB; }
.cal-cell.cal-today { background:#F0FAFC; }
.day-n { font-size:12px; font-weight:600; color:var(--gray-t); width:20px; height:20px; display:inline-flex; align-items:center; justify-content:center; border-radius:50%; margin-bottom:3px; flex-shrink:0; }
.day-n.today-n { background:var(--teal); color:white; font-weight:700; }
.cal-cell.cal-past .day-n { color:#BCC8CB; }
.cal-ev { font-size:10px; font-weight:500; padding:2px 4px; border-radius:3px; color:white; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; cursor:pointer; flex-shrink:0; transition:filter .1s; }
.cal-ev:hover { filter:brightness(1.12); }
.cal-ev.ev-done { opacity:.52; }
.cal-pe   { background:var(--c-pe); }
.cal-re   { background:var(--c-re); }
.cal-mkt  { background:var(--c-mkt); }
.cal-ppl  { background:var(--c-ppl); }
.cal-exec { background:var(--c-exec); }
.cal-cult { background:var(--c-cult); }
.cal-ptnr { background:var(--c-ptnr); }
.cal-tbc-section { margin-top:8px; margin-bottom:32px; }
.cal-tbc-title { font-size:14px; font-weight:600; margin-bottom:8px; }
.cal-tbc-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(210px,1fr)); gap:10px; }
.cal-tbc-card { background:white; border-radius:10px; border:1.5px solid var(--gray-b); border-left:3px solid #D84315; padding:12px 14px; cursor:pointer; transition:box-shadow .15s; }
.cal-tbc-card:hover { box-shadow:0 4px 12px rgba(0,0,0,.08); }
.cal-tbc-flag { font-size:10px; font-weight:700; color:#D84315; text-transform:uppercase; letter-spacing:.4px; margin-bottom:5px; }
.cal-tbc-name { font-size:13px; font-weight:600; color:var(--text); margin-bottom:6px; line-height:1.35; }
.cal-section-divider { height:1px; background:var(--gray-b); margin:4px 0 28px; }

/* ── MODAL ── */
.modal-backdrop { position:fixed; inset:0; background:rgba(0,0,0,.48); z-index:1000; display:none; align-items:center; justify-content:center; padding:24px; backdrop-filter:blur(2px); }
.modal-backdrop.open { display:flex; }
.modal { background:white; border-radius:16px; width:100%; max-width:560px; max-height:88vh; overflow-y:auto; position:relative; box-shadow:0 24px 60px rgba(0,0,0,.22); animation:modalIn .18s ease; }
@keyframes modalIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
.modal-close { position:absolute; top:14px; right:16px; width:30px; height:30px; border-radius:50%; border:none; background:var(--gray-l); color:var(--gray-t); font-size:16px; cursor:pointer; display:flex; align-items:center; justify-content:center; font-family:'Outfit',sans-serif; transition:background .12s; z-index:1; }
.modal-close:hover { background:var(--gray-b); color:var(--text); }
.modal-hdr { padding:24px 24px 0; }
.modal-badges { display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:10px; }
.modal-status { display:inline-flex; align-items:center; font-size:11px; font-weight:700; padding:3px 10px; border-radius:20px; }
.modal-date-badge { font-size:12px; font-weight:600; color:var(--teal-d); }
.modal-date-badge.tbc { color:#D84315; }
.modal-title { font-size:20px; font-weight:700; color:var(--text); letter-spacing:-.3px; line-height:1.3; margin-bottom:12px; padding-right:32px; }
.modal-chips { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:0; }
.modal-body { padding:20px 24px 24px; }
.modal-divider { height:1px; background:var(--gray-l); margin:16px 0; }
.modal-section-title { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.7px; color:var(--gray-m); margin-bottom:8px; }
.modal-desc { font-size:14px; color:var(--gray-t); line-height:1.65; }
.modal-meta-grid { display:grid; grid-template-columns:auto 1fr; gap:5px 12px; font-size:13px; }
.modal-meta-k { color:var(--gray-m); font-weight:600; font-size:11px; text-transform:uppercase; letter-spacing:.3px; padding-top:2px; }
.modal-meta-v { color:var(--gray-t); }
.modal-links-list { display:flex; flex-direction:column; gap:8px; }
.modal-link-btn { display:inline-flex; align-items:center; gap:7px; padding:9px 14px; background:var(--teal-l); color:var(--teal-deep); border-radius:8px; text-decoration:none; font-size:13px; font-weight:600; transition:background .12s; }
.modal-link-btn:hover { background:var(--teal-m); }
.modal-link-btn svg { flex-shrink:0; }
.modal-no-links { font-size:13px; color:var(--gray-m); padding:12px 14px; background:var(--gray-l); border-radius:8px; line-height:1.5; }
.modal-no-links code { font-size:11px; background:var(--gray-b); padding:2px 5px; border-radius:3px; font-family:monospace; color:var(--gray-t); }

/* ── FOOTER ── */
.footer { text-align:center; padding:18px; background:white; border-top:1px solid var(--gray-b); font-size:12px; color:var(--gray-m); }
.footer strong { color:var(--teal-d); }

/* ── RESPONSIVE ── */
@media(max-width:700px) {
  .header,.stats-bar,.main { padding-left:16px; padding-right:16px; }
  .top-controls { flex-direction:column; align-items:flex-start; }
  .stats-bar { height:auto; padding:10px 16px; flex-wrap:wrap; gap:10px; }
  .stat-item { padding:0 14px 0 0; border-right:none; }
  .cal-cell { min-height:72px; padding:4px 3px; }
  .cal-ev { font-size:9px; padding:1px 3px; }
  .day-n { font-size:10px; width:16px; height:16px; }
}
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div>
    <div class="hdr-eyebrow">Meltwater · APAC Enablement</div>
    <div class="hdr-title">Program Hub — May &amp; June 2026</div>
  </div>
  <div class="logo-wrap">
    <div class="logo-mark">M</div>
    <div class="logo-text">Meltwater</div>
  </div>
</div>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="stat-item"><div class="stat-num">15</div><div class="stat-label">May<br>programs</div></div>
  <div class="stat-item"><div class="stat-num">8</div><div class="stat-label">Completed<br>in May</div></div>
  <div class="stat-item"><div class="stat-num">15</div><div class="stat-label">June<br>programs</div></div>
  <div class="stat-item"><div class="stat-num">5</div><div class="stat-label">June<br>TBC</div></div>
</div>

<!-- MAIN -->
<div class="main">

  <!-- CONTROLS -->
  <div class="top-controls">
    <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
      <div class="view-toggle">
        <button class="view-btn active" onclick="switchView('list',this)">📋 List View</button>
        <button class="view-btn" onclick="switchView('cal',this)">📅 Calendar View</button>
      </div>
      <div class="month-tabs" id="month-tabs-wrap">
        <button class="month-btn active" onclick="switchMonth(5,this)">May 2026 <span class="month-btn-count" id="mc-may">15</span></button>
        <button class="month-btn" onclick="switchMonth(6,this)">June 2026 <span class="month-btn-count" id="mc-june">15</span></button>
      </div>
    </div>
    <div class="updated-label">Last updated: <strong>26 May 2026</strong></div>
  </div>

  <!-- ════ LIST VIEW ════ -->
  <div id="view-list" class="panel active">

    <div class="legend-bar">
      <span class="legend-title">Team</span>
      <div class="leg"><div class="leg-dot" style="background:var(--c-pe)"></div>Product Enablement</div>
      <div class="leg"><div class="leg-dot" style="background:var(--c-re)"></div>Role Excellence</div>
      <div class="leg"><div class="leg-dot" style="background:var(--c-ptnr)"></div>Partnerships</div>
      <div class="leg"><div class="leg-dot" style="background:var(--c-mkt)"></div>APAC Marketing</div>
      <div class="leg"><div class="leg-dot" style="background:var(--c-ppl)"></div>People Team</div>
      <div class="leg"><div class="leg-dot" style="background:var(--c-exec)"></div>Executive</div>
      <div class="leg"><div class="leg-dot" style="background:var(--c-cult)"></div>Culture</div>
      <div class="leg" style="margin-left:8px;padding-left:12px;border-left:1px solid var(--gray-b)">Click any card to view details</div>
    </div>

    <div class="filters-row">
      <span class="filter-label">Team</span>
      <button class="filter-btn active" data-ft="all" onclick="applyTeamFilter('all',this)">All</button>
      <button class="filter-btn" data-ft="Product Enablement" onclick="applyTeamFilter('Product Enablement',this)">Product Enablement</button>
      <button class="filter-btn" data-ft="Role Excellence" onclick="applyTeamFilter('Role Excellence',this)">Role Excellence</button>
      <button class="filter-btn" data-ft="APAC Marketing" onclick="applyTeamFilter('APAC Marketing',this)">APAC Marketing</button>
      <button class="filter-btn" data-ft="People Team" onclick="applyTeamFilter('People Team',this)">People Team</button>
      <button class="filter-btn" data-ft="Executive" onclick="applyTeamFilter('Executive',this)">Executive</button>
      <button class="filter-btn" data-ft="Partnerships" onclick="applyTeamFilter('Partnerships',this)">Partnerships</button>
      <button class="filter-btn" data-ft="Culture" onclick="applyTeamFilter('Culture',this)">Culture</button>
      <div class="filter-divider"></div>
      <span class="filter-label">Type</span>
      <button class="filter-btn" data-ftype="LIVE Session" onclick="applyTypeFilter('LIVE Session',this)">LIVE Session</button>
      <button class="filter-btn" data-ftype="eLearning" onclick="applyTypeFilter('eLearning',this)">eLearning</button>
      <button class="filter-btn" data-ftype="Customer Event" onclick="applyTypeFilter('Customer Event',this)">Customer Event</button>
    </div>

    <!-- MAY LIST PANEL -->
    <div id="list-may" class="panel active">
      <div class="ts-section"><div class="ts-heading">Team overview — May</div><div class="ts-grid" id="ts-may"></div></div>
      <div class="section-hdr"><div class="section-icon si-done">✓</div><div class="section-hdr-text"><h3>Completed</h3><p id="lbl-done"></p></div></div>
      <div class="cards-grid" id="grid-done"></div>
      <div class="section-hdr"><div class="section-icon si-up">⏳</div><div class="section-hdr-text"><h3>Still to go in May</h3><p id="lbl-up"></p></div></div>
      <div class="cards-grid" id="grid-up"></div>
    </div>

    <!-- JUNE LIST PANEL -->
