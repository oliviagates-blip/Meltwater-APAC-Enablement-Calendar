let activeTeam = "all", activeType = null;

function buildCard(ev) {
  const isTBC = ev.tbc, isDone = ev.done;
  const badge = isTBC ? '<span class="card-badge b-tbc">📌 Date TBC</span>' : isDone ? '<span class="card-badge b-done">✓ Completed</span>' : '<span class="card-badge b-up">⏳ Upcoming</span>';
  const dateTxt = isTBC ? "📅 TBC" : "📅 " + ev.day + (ev.month===5?" May":" Jun");
  const cls = ["card", isTBC?"tbc-card":"", isDone?"completed-card":""].filter(Boolean).join(" ");
  return `<div class="${cls}" data-teams="${ev.team}" data-type="${ev.type}" onclick="openModal(${ev.id})">
    <div class="card-top">${badge}<span class="card-date${isTBC?" tbc-d":""}">${dateTxt}</span></div>
    <div class="card-title">${ev.name}</div>
    <div class="card-divider"></div>
    <div class="card-meta">
      <div class="meta-row"><div class="meta-key">Team</div><div class="meta-val chip-row">${chipHtml(ev.team)}</div></div>
      <div class="meta-row"><div class="meta-key">Area</div><div class="meta-val">${ev.area}</div></div>
      <div class="meta-row"><div class="meta-key">For</div><div class="meta-val">${ev.aud}</div></div>
