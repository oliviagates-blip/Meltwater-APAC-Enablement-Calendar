/* ── CALENDAR RENDERING ──────────────────────────────────────── */
function buildCalendar(containerId, year, month) {
  const container = document.getElementById(containerId);
  container.innerHTML = "";
  const firstDay = new Date(year, month-1, 1);
  const total    = new Date(year, month, 0).getDate();
  const startDow = (firstDay.getDay() + 6) % 7;
  const TODAY    = new Date(2026, 4, 26);
  const evByDay  = {};
  EVENTS.filter(e => e.month === month && !e.tbc).forEach(ev => {
    if (!evByDay[ev.day]) evByDay[ev.day] = [];
    evByDay[ev.day].push(ev);
  });
  ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"].forEach(d => {
    const h = document.createElement("div"); h.className="cal-dow"; h.textContent=d; container.appendChild(h);
  });
  for (let i=0;i<startDow;i++) { const e=document.createElement("div"); e.className="cal-cell empty"; container.appendChild(e); }
  for (let day=1;day<=total;day++) {
    const cd = new Date(year,month-1,day);
    const isToday = year===2026&&month===5&&day===26;
    const isPast  = cd < TODAY && !isToday;
    const col     = (startDow+day-1)%7;
    const cell    = document.createElement("div");
    cell.className = "cal-cell " + (isToday?"cal-today":isPast?"cal-past":col>=5?"cal-weekend":"");
    const dn = document.createElement("div");
    dn.className = isToday ? "day-n today-n" : "day-n";
    dn.textContent = day;
    cell.appendChild(dn);
    (evByDay[day]||[]).forEach(ev => {
      const e = document.createElement("div");
      e.className = "cal-ev cal-" + tkey(ev.team) + (ev.done?" ev-done":"");
      e.textContent = ev.short;
      e.title = ev.name + " — " + ev.team;
      e.onclick = () => openModal(ev.id);
      cell.appendChild(e);
    });
    container.appendChild(cell);
  }
  const used = startDow + total;
  const rem  = used % 7;
  if (rem > 0) for (let i=0;i<7-rem;i++) { const e=document.createElement("div"); e.className="cal-cell empty"; container.appendChild(e); }
}

function buildCalTBC() {
  const container = document.getElementById("cal-tbc");
  EVENTS.filter(e=>e.tbc).forEach(ev => {
    const c = document.createElement("div");
    c.className = "cal-tbc-card";
    c.onclick = () => openModal(ev.id);
    c.innerHTML = `<div class="cal-tbc-flag">📌 Date TBC</div><div class="cal-tbc-name">${ev.name}</div><span class="chip chip-${tkey(ev.team)}">${ev.team}</span>`;
    container.appendChild(c);
  });
}

/* ── MODAL ───────────────────────────────────────────────────── */
function openModal(id) {
  const ev = EVENTS.find(e => e.id === id);
  if (!ev) return;
  const isTBC = ev.tbc, isDone = ev.done;
  const statusBg = isTBC ? "#FFF3E0" : isDone ? "#E8F5E9" : "#E0F5F7";
  const statusCol = isTBC ? "#D84315" : isDone ? "#2E7D32" : "#00737E";
  const statusLbl = isTBC ? "📌 Date TBC" : isDone ? "✓ Completed" : "⏳ Upcoming";
  const sEl = document.getElementById("m-status");
  sEl.style.background = statusBg; sEl.style.color = statusCol; sEl.textContent = statusLbl;
  const dateStr = isTBC ? "Date to be confirmed" : ev.day + (ev.month===5?" May 2026":" June 2026");
  const dateCls = isTBC ? "modal-date-badge tbc" : "modal-date-badge";
  document.getElementById("m-date").className = dateCls;
  document.getElementById("m-date").textContent = "📅 " + dateStr;
  document.getElementById("m-title").textContent = ev.name;
  document.getElementById("m-chips").innerHTML = chipHtml(ev.team) + ` <span class="type-chip">${ev.type}</span>`;
  document.getElementById("m-desc").textContent = ev.desc;
  document.getElementById("m-meta").innerHTML = `
    <div class="modal-meta-k">Area</div><div class="modal-meta-v">${ev.area}</div>
    <div class="modal-meta-k">Audience</div><div class="modal-meta-v">${ev.aud}</div>
    <div class="modal-meta-k">Type</div><div class="modal-meta-v">${ev.type}</div>`;
  const linksEl = document.getElementById("m-links");
  if (ev.links && ev.links.length > 0) {
    linksEl.innerHTML = '<div class="modal-links-list">' + ev.links.map(l =>
      `<a class="modal-link-btn" href="${l.url}" target="_blank" rel="noopener"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3"/></svg>${l.label}</a>`
    ).join("") + "</div>";
  } else {
    const hint = isDone
      ? `<div class="modal-no-links">No resources added yet for this event.<br><small>To add links, open this file in a text editor and update the <code>links</code> array for event ID ${ev.id}.</small></div>`
      : `<div class="modal-no-links">Resources will be added after the session is delivered.</div>`;
    linksEl.innerHTML = hint;
  }
  document.getElementById("modal-backdrop").classList.add("open");
  document.body.style.overflow = "hidden";
}
function closeModal() {
  document.getElementById("modal-backdrop").classList.remove("open");
  document.body.style.overflow = "";
}
function closeModalOutside(e) { if (e.target === document.getElementById("modal-backdrop")) closeModal(); }
document.addEventListener("keydown", e => { if (e.key === "Escape") closeModal(); });

/* ── FILTERS ─────────────────────────────────────────────────── */
function applyTeamFilter(team, btn) {
  activeTeam = team;
  document.querySelectorAll("[data-ft]").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
  applyFilters();
}
function applyTypeFilter(type, btn) {
  if (activeType === type) { activeType = null; btn.classList.remove("active"); }
  else { activeType = type; document.querySelectorAll("[data-ftype]").forEach(b => b.classList.remove("active")); btn.classList.add("active"); }
  applyFilters();
}
function applyFilters() {
  document.querySelectorAll(".card").forEach(c => {
    const ok = (activeTeam==="all"||c.dataset.teams.indexOf(activeTeam)!==-1) && (!activeType||c.dataset.type===activeType);
    c.classList.toggle("hidden", !ok);
  });
  document.getElementById("mc-may").textContent  = document.querySelectorAll("#list-may .card:not(.hidden)").length;
  document.getElementById("mc-june").textContent = document.querySelectorAll("#list-june .card:not(.hidden)").length;
}

/* ── VIEW / MONTH SWITCHING ──────────────────────────────────── */
let curView = "list", curMonth = 5;
function switchView(view, btn) {
  curView = view;
  document.querySelectorAll(".view-btn").forEach(b => b.classList.remove("active")); btn.classList.add("active");
  document.getElementById("view-list").classList.toggle("active", view==="list");
  document.getElementById("view-cal").classList.toggle("active",  view==="cal");
  document.getElementById("month-tabs-wrap").style.display = view==="list" ? "" : "none";
}
function switchMonth(month, btn) {
  curMonth = month;
  document.querySelectorAll(".month-btn").forEach(b => b.classList.remove("active")); btn.classList.add("active");
  document.getElementById("list-may").classList.toggle("active",  month===5);
  document.getElementById("list-june").classList.toggle("active", month===6);
}

/* ── INIT ────────────────────────────────────────────────────── */
renderListMonth(5);
renderListMonth(6);
buildCalendar("cal-may",  2026, 5);
buildCalendar("cal-june", 2026, 6);
buildCalTBC();
document.getElementById("mc-may").textContent  = EVENTS.filter(e=>e.month===5).length;
document.getElementById("mc-june").textContent = EVENTS.filter(e=>e.month===6).length;

</script>
