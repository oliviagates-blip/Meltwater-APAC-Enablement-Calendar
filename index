/* ── TEAM SUMMARIES ──────────────────────────────────────────── */
const TEAM_ORDER = ["Product Enablement","Role Excellence","APAC Marketing","People Team","Executive","Partnerships","Culture"];

function buildTeamSummaries(month, containerId) {
  const container = document.getElementById(containerId);
  container.innerHTML = "";
  const confirmed = EVENTS.filter(e => e.month === month && !e.tbc);
  const byTeam = {};
  confirmed.forEach(ev => {
    ev.team.split(",").map(t => t.trim()).forEach(t => {
      if (!byTeam[t]) byTeam[t] = [];
      if (!byTeam[t].find(x => x.id === ev.id)) byTeam[t].push(ev);
    });
  });
  TEAM_ORDER.forEach(team => {
    if (!byTeam[team]) return;
    const evs = byTeam[team];
    const shorts = evs.map(e => e.short);
    let desc = shorts.length === 1 ? shorts[0] : shorts.length === 2 ? shorts[0] + " and " + shorts[1] : shorts.slice(0,-1).join(", ") + ", and " + shorts[shorts.length-1];
    const key = tkey(team);
    const color = tcolor(team);
    const card = document.createElement("div");
    card.className = "ts-card";
    card.style.borderLeftColor = color;
    card.innerHTML = `<div><span class="chip chip-${key} ts-badge">${team}</span></div><div class="ts-count">${evs.length} program${evs.length>1?"s":""} this month</div><div class="ts-desc">${desc}</div>`;
    container.appendChild(card);
  });
  if (month === 6) {
    const tbcEvs = EVENTS.filter(e => e.month === 6 && e.tbc);
    if (tbcEvs.length) {
      const card = document.createElement("div");
      card.className = "ts-card";
      card.style.borderLeftColor = "#D84315";
      card.innerHTML = `<div><span class="ts-badge" style="background:#FFF3E0;color:#8D4300;font-size:11px;font-weight:600;padding:2px 8px;border-radius:4px;">📌 TBC</span></div><div class="ts-count">${tbcEvs.length} programs pending date</div><div class="ts-desc">${tbcEvs.map(e=>e.short).join(", ")}</div>`;
      container.appendChild(card);
    }
  }
}

